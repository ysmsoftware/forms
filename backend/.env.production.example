# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.production  —  copy this file, fill in all values, never commit
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3005
DOMAIN=https://yourdomain.com
BASE_URL=https://api.yourdomain.com/api
FRONTEND_URL=https://yourdomain.com

# Auth
JWT_ACCESS_SECRET=CHANGE_ME_STRONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_STRONG_RANDOM_STRING

# Database (Neon or any Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis
# NOTE: REDIS_HOST and REDIS_PORT are overridden by docker-compose.prod.yml
# to use the Docker service name. These values are used for local dev only.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# File storage
FILE_STORAGE_DRIVER=local           # or "s3"
LOCAL_PUBLIC_URL=https://api.yourdomain.com

# AWS S3 (only needed when FILE_STORAGE_DRIVER=s3)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_PUBLIC_URL=

# Email (SMTP)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USER=support@yourdomain.com
SMTP_PASS=

# WhatsApp (AiSensy)
WHATSAPP_OTP_API_URL=https://backend.aisensy.com/campaign/t1/api/v2
WHATSAPP_OTP_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
